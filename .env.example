## Moonshot / Kimi config (Vite env vars must start with VITE_)
# Frontend calls this path (same-origin). Vite will proxy it to the local server.
VITE_MOONSHOT_CHAT_COMPLETIONS_URL=/api/chat/completions

# Model name
# kimi-k2.6 = K2.7 Code 关闭 thinking 的实际路由（此时 temperature 仅允许 0.6，代码已自动处理）
VITE_MOONSHOT_MODEL=kimi-k2.6

# Optional: default temperature
VITE_MOONSHOT_TEMPERATURE=0.6

## Server-side (DO NOT prefix with VITE_)
# Your real Moonshot API key lives only on the server
# MOONSHOT_API_KEY=sk-xxxxxxxx

# Upstream endpoint (official)
MOONSHOT_UPSTREAM=https://api.moonshot.cn/v1/chat/completions

# Local proxy port (optional)
# PORT=5176

